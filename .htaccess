# ========================================================
# 1. CPANEL PHP HANDLER
# ========================================================
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>

# ========================================================
# 2. CORE SECURITY & SETTINGS
# ========================================================
Options -Indexes
DirectoryIndex index.php index.html
RewriteEngine On
RewriteBase /

# ========================================================
# HOSTINGER CDN: Search crawlers must NOT be geo-blocked.
# If Bing/Yahoo show "Your country is not allowed" → hPanel → CDN → Traffic blocking → remove country rules.
# ========================================================

# Allow verified search-engine crawlers (Apache/LiteSpeed layer + IP ranges)
<IfModule mod_setenvif.c>
  SetEnvIfNoCase User-Agent "bingbot|BingPreview|msnbot|adidxbot|Googlebot|Google-InspectionTool|Googlebot-Image|AdsBot-Google|Mediapartners-Google|Storebot-Google|Slurp|Yahoo|YahooSeeker|YahooBot|DuckDuckBot|YandexBot|Applebot|Baiduspider|facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Pinterestbot|SemrushBot|AhrefsBot|PetalBot|Bytespider|MJ12bot|DotBot" search_engine_bot=1
  SetEnvIf Remote_Addr "^40\.7[7-9]\." search_engine_bot=1
  SetEnvIf Remote_Addr "^40\.8[0-9]\." search_engine_bot=1
  SetEnvIf Remote_Addr "^157\.5[56]\." search_engine_bot=1
  SetEnvIf Remote_Addr "^207\.46\." search_engine_bot=1
  SetEnvIf Remote_Addr "^13\.6[6-9]\." search_engine_bot=1
  SetEnvIf Remote_Addr "^52\.167\." search_engine_bot=1
  SetEnvIf Remote_Addr "^65\.5[25]\." search_engine_bot=1
  SetEnvIf Remote_Addr "^66\.249\." search_engine_bot=1
  SetEnvIf Remote_Addr "^64\.233\." search_engine_bot=1
  SetEnvIf Remote_Addr "^72\.14\." search_engine_bot=1
  SetEnvIf Remote_Addr "^74\.125\." search_engine_bot=1
  SetEnvIf Remote_Addr "^209\.85\." search_engine_bot=1
  SetEnvIf Remote_Addr "^216\.(58|239)\." search_engine_bot=1
  SetEnvIf Remote_Addr "^66\.196\." search_engine_bot=1
  SetEnvIf Remote_Addr "^68\.142\." search_engine_bot=1
  SetEnvIf Remote_Addr "^72\.30\." search_engine_bot=1
  SetEnvIf Remote_Addr "^98\.13[6-9]\." search_engine_bot=1
  SetEnvIf Remote_Addr "^5\.255\." search_engine_bot=1
  SetEnvIf Remote_Addr "^87\.250\." search_engine_bot=1
  SetEnvIf Remote_Addr "^93\.158\." search_engine_bot=1
  SetEnvIf Remote_Addr "^17\.(58|248)\." search_engine_bot=1
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Robots-Tag "index, follow, max-image-preview:large" env=search_engine_bot
</IfModule>

# ========================================================
# 3. SITEMAP, LLMS & RSS REWRITE
# ========================================================
RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^llms\.txt$ llms.php [L]
RewriteRule ^rss\.xml$ rss.php [L]
RewriteRule ^news-sitemap\.xml$ news-sitemap.php [L]
RewriteRule ^discover-feed\.xml$ discover-feed.php [L]
RewriteRule ^atom\.xml$ atom.php [L]

# ========================================================
# 3C. TOOLS MARKETPLACE
# ========================================================
RewriteRule ^tools/?$ tools/index.php [L]
RewriteRule ^tools/([a-z0-9-]+)/?$ tools/tool.php?slug=$1 [L,QSA]
RewriteRule ^process/?$ process.php [L]
RewriteRule ^api/chatbot/?$ api/chatbot.php [L,QSA]
RewriteRule ^api/translate/?$ api/translate.php [L,QSA]

# ========================================================
# 3B. CITY LANDING PAGES
# ========================================================
RewriteRule ^digital-agency-([a-z]+)$ city-page.php?city=$1 [L,QSA]

# ========================================================
# 4. FORCE HTTPS & WWW
# ========================================================
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.nectradigital.com/$1 [L,R=301]

# ========================================================
# 5. REMOVE TRAILING SLASH
# ========================================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# ========================================================
# 5B. CRAWLER STATIC BLOG SNAPSHOTS (bypass Hostinger hCDN/WAF 403)
# ========================================================
RewriteCond %{ENV:search_engine_bot} =1 [OR]
RewriteCond %{HTTP_USER_AGENT} (bingbot|BingPreview|msnbot|adidxbot|Googlebot|Google-InspectionTool|Googlebot-Image|AdsBot-Google|Mediapartners-Google|Slurp|Yahoo|YahooSeeker|YahooBot|DuckDuckBot|YandexBot|Applebot|SemrushBot|AhrefsBot|PetalBot|Bytespider) [NC]
RewriteCond %{DOCUMENT_ROOT}/storage/blog-static/$1.html -f
RewriteRule ^([a-zA-Z0-9-]+)$ storage/blog-static/$1.html [L]

# ========================================================
# 6. PRIORITY 1: REAL PAGES (Clean URLs)
# If a user visits /services, check if services.php exists.
# If yes, load it and STOP ([L]).
# ========================================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# ========================================================
# 7. PRIORITY 2: BLOG POSTS (Catch-All)
# If it wasn't a real page (handled above), assume it's a slug.
# Maps: /best-hosting-deal -> post.php?slug=best-hosting-deal
# ========================================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9-]+)$ page-router.php?slug=$1 [L,QSA]

# ========================================================
# 8. ERROR PAGES
# ========================================================
ErrorDocument 404 /404.php
ErrorDocument 500 /index.php

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
